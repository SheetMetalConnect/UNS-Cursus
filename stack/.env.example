# ==============================================================================
# UNS Cursus — Environment Variables
# ==============================================================================
# Kopieer dit bestand naar .env en vul je AUTH_TOKEN in:
#   cp .env.example .env
#
# AUTH_TOKEN krijg je gratis via https://management.umh.app/
# ==============================================================================

# VERPLICHT: jouw token van de Management Console
AUTH_TOKEN=<plak-hier-je-token>

# Locatie in de UNS hierarchy (pas aan naar jouw bedrijf)
LOCATION_0=mijnbedrijf
LOCATION_1=mijnsite
