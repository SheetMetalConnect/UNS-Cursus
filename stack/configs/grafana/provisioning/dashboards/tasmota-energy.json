    {
      "type": "timeseries",
      "title": "Power (W) Over Time",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "postgres",
        "uid": "umh-timescaledb"
      },
      "targets": [
        {
          "rawSql": "SELECT\n  time_bucket('30 seconds', t.time) AS time,\n  a.line AS metric,\n  avg(t.value) AS \"Power\"\nFROM tag t\nJOIN asset a ON a.id = t.asset_id\nWHERE $__timeFilter(t.time)\n  AND a.enterprise = 'smc'\n  AND t.tag_name = 'power'\nGROUP BY 1, 2\nORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
