    {
      "type": "stat",
      "title": "Desk \u2014 Power (W)",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "postgres",
        "uid": "umh-timescaledb"
      },
      "targets": [
        {
          "rawSql": "SELECT t.value AS \"Power\"\nFROM tag t\nJOIN asset a ON a.id = t.asset_id\nWHERE a.line = 'desk' AND a.enterprise = 'smc'\n  AND t.tag_name = 'power'\nORDER BY t.time DESC\nLIMIT 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
