    {
      "type": "stat",
      "title": "Laser \u2014 Current State",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "postgres",
        "uid": "umh-timescaledb"
      },
      "targets": [
        {
          "rawSql": "SELECT t.value AS \"State\"\nFROM tag t\nJOIN asset a ON a.id = t.asset_id\nWHERE a.line = 'laser_01' AND a.enterprise = 'metalfab'\n  AND t.tag_name = 'state'\nORDER BY t.time DESC\nLIMIT 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "STOPPED",
                  "color": "red",
                  "index": 0
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "text": "IDLE",
                  "color": "yellow",
                  "index": 1
                }
              }
            },
            {
              "type": "value",
              "options": {
                "3": {
                  "text": "EXECUTE",
                  "color": "green",
                  "index": 2
                }
              }
            },
            {
              "type": "value",
              "options": {
                "5": {
                  "text": "HELD",
                  "color": "orange",
                  "index": 3
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "green",
                "value": 3
              },
              {
                "color": "orange",
                "value": 5
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "type": "gauge",
      "title": "Laser \u2014 Laser Power",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "datasource": {
        "type": "postgres",
        "uid": "umh-timescaledb"
      },
      "targets": [
        {
          "rawSql": "SELECT t.value AS \"Laser Power\"\nFROM tag t\nJOIN asset a ON a.id = t.asset_id\nWHERE a.line = 'laser_01' AND a.enterprise = 'metalfab'\n  AND t.tag_name = 'laser_power'\nORDER BY t.time DESC\nLIMIT 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "type": "timeseries",
      "title": "Laser \u2014 Power & Cutting Speed",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "datasource": {
        "type": "postgres",
        "uid": "umh-timescaledb"
      },
      "targets": [
        {
          "rawSql": "SELECT\n  time_bucket('30 seconds', t.time) AS time,\n  avg(t.value) AS \"laser_power\"\nFROM tag t\nJOIN asset a ON a.id = t.asset_id\nWHERE $__timeFilter(t.time)\n  AND a.line = 'laser_01' AND a.enterprise = 'metalfab'\n  AND t.tag_name = 'laser_power'\nGROUP BY 1\nORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT\n  time_bucket('30 seconds', t.time) AS time,\n  avg(t.value) AS \"cutting_speed\"\nFROM tag t\nJOIN asset a ON a.id = t.asset_id\nWHERE $__timeFilter(t.time)\n  AND a.line = 'laser_01' AND a.enterprise = 'metalfab'\n  AND t.tag_name = 'cutting_speed'\nGROUP BY 1\nORDER BY 1;",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Laser \u2014 OEE Metrics",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 1
