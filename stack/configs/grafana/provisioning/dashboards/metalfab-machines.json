      "targets": [
        {
          "rawSql": "SELECT\n  time_bucket('30 seconds', t.time) AS time,\n  t.tag_name AS metric,\n  avg(t.value) AS value\nFROM tag t\nJOIN asset a ON a.id = t.asset_id\nWHERE $__timeFilter(t.time)\n  AND a.line = 'laser_01' AND a.enterprise = 'metalfab'\n  AND t.tag_name IN ('oee.availability', 'oee.quality', 'oee.performance', 'oee.oee')\nGROUP BY 1, 2\nORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
