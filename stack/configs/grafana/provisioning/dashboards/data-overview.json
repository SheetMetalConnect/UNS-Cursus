    {
      "type": "table",
      "title": "Asset Registry",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "umh-timescaledb"
      },
      "targets": [
        {
          "rawSql": "SELECT\n  a.enterprise,\n  a.site,\n  a.area,\n  a.line,\n  COALESCE(tc.tag_count, 0) AS \"Tag Count\",\n  tc.last_data AS \"Last Data\"\nFROM asset a\nLEFT JOIN (\n  SELECT\n    asset_id,\n    count(DISTINCT tag_name) AS tag_count,\n    max(time) AS last_data\n  FROM tag\n  WHERE time > NOW() - INTERVAL '1 hour'\n  GROUP BY asset_id\n) tc ON tc.asset_id = a.id\nORDER BY a.enterprise, a.site, a.area, a.line;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": []
      }
    },
    {
      "type": "timeseries",
      "title": "Write Rate (inserts/min)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "umh-timescaledb"
      },
      "targets": [
        {
          "rawSql": "SELECT\n  time_bucket('1 minute', t.time) AS time,\n  count(*) AS \"inserts\"\nFROM tag t\nWHERE $__timeFilter(t.time)\nGROUP BY 1\nORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "barAlignment": 0,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "gradientMode": "scheme",
            "axisLabel": "Inserts"
          },
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "type": "table",
      "title": "Latest State Changes (tag_string)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "umh-timescaledb"
      },
      "targets": [
        {
          "rawSql": "SELECT\n  ts.time AS \"Time\",\n  a.line AS \"Machine\",\n  ts.tag_name AS \"Tag\",\n  ts.value AS \"Value\"\nFROM tag_string ts\nJOIN asset a ON a.id = ts.asset_id\nWHERE $__timeFilter(ts.time)\nORDER BY ts.time DESC\nLIMIT 50;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Time",
            "desc": true
          }
        ]
      }
    }
  ],
  "refresh": "10s",
